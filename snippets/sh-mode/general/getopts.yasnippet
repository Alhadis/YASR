# -*- mode: snippet -*-
# key: getopts
# name: Getopts built-in
# group: General
# atom-selector: .source.shell
# --
while getopts ${1:n\:h} ${2:option}; do
	case \$${2:option} in
		${3:${4:n}) ${5:name=\$OPTARG};;}
		*) echo >&2 "Usage: ${6:\${0\}: ${7:[-n name]}}";;
	esac
done; shift \$((OPTIND-1))
$0